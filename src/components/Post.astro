---
import type { CollectionEntry } from "astro:content";
import FormattedDate from "./FormattedDate.astro";

type Props = { post: CollectionEntry<"blog"> };

const { post } = Astro.props;
---

<li
  class="bg-white rounded-lg shadow-md p-6 border border-gray-200 hover:shadow-lg transition-all duration-300"
>
  <div class="flex flex-col md:flex-row md:items-center md:justify-between">
    <div class="mb-2 md:mb-0">
      <a
        href={`/blog/${post.id}`}
        class="text-lg font-semibold text-gray-900 hover:text-pink-800 transition-colors"
        >{post.data.title}</a
      >
    </div>
    <div>
      <FormattedDate date={post.data.pubDate} class="text-sm text-gray-500" />
    </div>
  </div>
</li>
