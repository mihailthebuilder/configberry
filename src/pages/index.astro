---
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import BaseHead from "@components/BaseHead.astro";
import { SITE_TITLE, SITE_DESCRIPTION, CONTACT_FORM_URL } from "../consts";

const faq = [
  {
    question: "I want feature X, can you add it?",
    answer: `Send me a message on <a href="https://www.linkedin.com/in/mihailmarian" class="text-pink-800 hover:text-pink-600">LinkedIn</a> or via this <a href="${CONTACT_FORM_URL}" class="text-pink-800 hover:text-pink-600 inline-block">contact form</a>. This is an early version, and I\'m trying to figure out what to prioritise building next.`,
  },
  {
    question: "What Cloudflare settings can I manage with this platform?",
    answer:
      "Only Cloudflare WAF security rules at the moment. See 1st question for how to request more features.",
  },
  {
    question: "Can I use API tokens?",
    answer:
      "Not yet. I'm assuming that most people will be using the API key since it's convenient.",
  },
  {
    question: "How secure is this tool?",
    answer:
      "The tool doesn't store the emails or API keys you enter, so I'd like to think it's pretty secure.",
  },
];

const steps = [
  {
    title: "Prepare Your Zone List",
    description:
      "Create a CSV with zone IDs, names, API emails, and API keys for your target sites, and the same information for the source zone.",
  },
  {
    title: "Enter Details",
    description:
      "Upload the source and target zone credentials in the WAF Sync Tool.",
  },
  {
    title: "Apply Changes",
    description:
      "Verify the planned changes and apply them across all your zones.",
  },
];
---

<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-gray-50 text-gray-900">
    <Header />

    <main>
      <section class="bg-gradient-to-br from-gray-900 to-gray-800 text-white">
        <div class="max-w-7xl mx-auto px-6 py-16 md:py-20">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div>
              <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-4">
                Manage Cloudflare configs for multiple domains, at scale
              </h1>
              <p class="text-gray-300 text-lg mb-8">
                The easiest way to manage Cloudflare settings across all your
                zones. Save hours of manual configuration, ensure consistency,
                and strengthen your security posture.
              </p>
              <div class="flex flex-col sm:flex-row gap-4 mb-8">
                <a
                  href="/waf-sync"
                  class="bg-pink-800 hover:bg-pink-600 text-white font-medium py-3 px-6 rounded-lg text-center transition-colors"
                >
                  Free WAF Sync Tool
                </a>
                <a
                  href="/export-zones"
                  class="bg-transparent border border-white hover:bg-white hover:text-gray-900 text-white font-medium py-3 px-6 rounded-lg text-center transition-colors"
                >
                  Free Zone Export Tool
                </a>
              </div>
            </div>

            <div class="mx-auto lg:mx-0 w-full max-w-2xl">
              <div
                class="relative rounded-lg overflow-hidden shadow-2xl bg-gray-800 border border-gray-700"
              >
                <div class="aspect-w-16 aspect-h-9">
                  <!-- Replace with your actual video embed -->
                  <div
                    class="w-full h-full flex items-center justify-center bg-gray-800"
                  >
                    <div class="text-center p-6">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-16 w-16 text-pink-800 mx-auto mb-4"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"
                        ></path>
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                      </svg>
                      <p class="text-gray-400">
                        Watch Demo: How to Sync WAF Rules
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
      <section class="bg-gray-100 py-16">
        <div class="max-w-7xl mx-auto px-6">
          <div class="text-center mb-12">
            <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
              How It Works
            </h2>
            <p class="text-lg text-gray-600 max-w-3xl mx-auto">
              Synchronize your Cloudflare WAF security rules across multiple
              domains in {steps.length} simple steps
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {
              steps.map((step, index) => (
                <div class="bg-white p-6 rounded-lg shadow-md">
                  <div class="flex items-center mb-4">
                    <div class="flex items-center justify-center h-12 w-12 rounded-full bg-pink-100 text-pink-800 font-bold text-xl mr-4">
                      {index + 1}
                    </div>
                    <h3 class="font-semibold text-xl">{step.title}</h3>
                  </div>
                  <p class="text-gray-600">{step.description}</p>
                </div>
              ))
            }
          </div>

          <div class="mt-12 text-center">
            <a
              href="/waf-sync"
              class="bg-pink-800 hover:bg-pink-600 text-white font-medium py-3 px-8 rounded-lg transition-colors"
            >
              Free WAF Sync Tool
            </a>
          </div>
        </div>
      </section>
      <!-- FAQ Section -->
      <section class="bg-gray-100 py-16">
        <div class="max-w-7xl mx-auto px-6">
          <div class="text-center mb-12">
            <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
              Frequently Asked Questions
            </h2>
          </div>

          <div class="grid gap-6 md:grid-cols-2 max-w-4xl mx-auto">
            {
              faq.map((item) => (
                <div class="bg-white rounded-lg shadow-md p-6 border border-gray-200">
                  <h3 class="text-xl font-semibold text-gray-900 mb-3">
                    {item.question}
                  </h3>
                  <p class="text-gray-700" set:html={item.answer} />
                </div>
              ))
            }
          </div>

          <div class="text-center mt-10">
            <a
              href="/waf-sync"
              class="inline-flex items-center bg-pink-800 hover:bg-pink-600 text-white font-medium py-3 px-6 rounded-lg transition-colors"
            >
              Free WAF Sync Tool
            </a>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
