---
import "@styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>WAF Rules Manager | Bulk Cloudflare WAF Rule Management</title>
  </head>
  <body class="bg-gray-50 text-gray-900">
    <nav class="bg-white border-b border-gray-200 py-4 px-6 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto flex justify-between items-center">
        <div class="flex items-center space-x-2">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-8 w-8 text-orange-500"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
            <path d="M2 17l10 5 10-5"></path>
            <path d="M2 12l10 5 10-5"></path>
          </svg>
          <span class="font-bold text-xl text-gray-800">CloudSync</span>
        </div>

        <div class="hidden md:flex space-x-8">
          <a href="/" class="text-gray-700 hover:text-orange-500 font-medium"
            >Home</a
          >
          <a
            href="/app/waf-copy"
            class="text-gray-700 hover:text-orange-500 font-medium"
            >WAF Sync Tool</a
          >
          <a
            href="/app/zone-waf-export"
            class="text-gray-700 hover:text-orange-500 font-medium"
            >Zone Export Tool</a
          >
          <a
            href="/blog"
            class="text-gray-700 hover:text-orange-500 font-medium">Blog</a
          >
        </div>

        <div class="md:hidden">
          <button id="mobile-menu-button" class="text-gray-700">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-6 w-6"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile menu, toggle visibility with JavaScript -->
      <div id="mobile-menu" class="hidden md:hidden mt-4 pb-2">
        <div class="flex flex-col space-y-3">
          <a href="/" class="text-gray-700 hover:text-orange-500 font-medium"
            >Home</a
          >
          <a
            href="/app/waf-sync"
            class="text-gray-700 hover:text-orange-500 font-medium"
            >WAF Sync Tool</a
          >
          <a
            href="/app/zone-waf-export"
            class="text-gray-700 hover:text-orange-500 font-medium"
            >Data Export Tool</a
          >
          <a
            href="/blog"
            class="text-gray-700 hover:text-orange-500 font-medium">Blog</a
          >
        </div>
      </div>
    </nav>

    <script>
      // Mobile menu toggle
      document
        .getElementById("mobile-menu-button")
        ?.addEventListener("click", () => {
          const menu = document.getElementById("mobile-menu");
          menu?.classList.toggle("hidden");
        });
    </script>

    <main>
      <!-- src/components/Hero.astro -->
      <section class="bg-gradient-to-br from-gray-900 to-gray-800 text-white">
        <div class="max-w-7xl mx-auto px-6 py-16 md:py-20">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div>
              <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-4">
                Apply Cloudflare WAF Configs Across Multiple Sites
              </h1>
              <p class="text-gray-300 text-lg mb-8">
                Apply Cloudflare WAF rules to all your websites with just a few
                clicks. Save hours of manual configuration, ensure consistency,
                and strengthen your security posture.
              </p>
              <div class="flex flex-col sm:flex-row gap-4 mb-8">
                <a
                  href="/app/waf-copy"
                  class="bg-orange-500 hover:bg-orange-600 text-white font-medium py-3 px-6 rounded-lg text-center transition-colors"
                >
                  Go to WAF Sync Tool
                </a>
                <a
                  href="/app/zone-waf-export"
                  class="bg-transparent border border-white hover:bg-white hover:text-gray-900 text-white font-medium py-3 px-6 rounded-lg text-center transition-colors"
                >
                  Zone Export Tool
                </a>
              </div>
            </div>

            <div class="mx-auto lg:mx-0 w-full max-w-2xl">
              <div
                class="relative rounded-lg overflow-hidden shadow-2xl bg-gray-800 border border-gray-700"
              >
                <div class="aspect-w-16 aspect-h-9">
                  <!-- Replace with your actual video embed -->
                  <div
                    class="w-full h-full flex items-center justify-center bg-gray-800"
                  >
                    <div class="text-center p-6">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-16 w-16 text-orange-500 mx-auto mb-4"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"
                        ></path>
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                      </svg>
                      <p class="text-gray-400">
                        Watch Demo: How to Sync WAF Rules
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-gray-800 py-4">
          <div class="max-w-7xl mx-auto px-6 text-center">
            <p class="text-gray-400">
              Secure your websites faster and more efficiently
            </p>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
