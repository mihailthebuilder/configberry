---
import "@styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>WAF Rules Manager | Bulk Cloudflare WAF Rule Management</title>
  </head>
  <body class="bg-gray-50 text-gray-900">
    <nav class="bg-white border-b border-gray-200 py-4 px-6 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto flex justify-between items-center">
        <div class="flex items-center space-x-2">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-8 w-8 text-orange-500"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
            <path d="M2 17l10 5 10-5"></path>
            <path d="M2 12l10 5 10-5"></path>
          </svg>
          <span class="font-bold text-xl text-gray-800">CloudSync</span>
        </div>

        <div class="hidden md:flex space-x-8">
          <a href="/" class="text-gray-700 hover:text-orange-500 font-medium"
            >Home</a
          >
          <a
            href="/app/waf-copy"
            class="text-gray-700 hover:text-orange-500 font-medium"
            >WAF Sync Tool</a
          >
          <a
            href="/app/export-zones"
            class="text-gray-700 hover:text-orange-500 font-medium"
            >Zone Export Tool</a
          >
          <a
            href="/blog"
            class="text-gray-700 hover:text-orange-500 font-medium">Blog</a
          >
        </div>

        <div class="md:hidden">
          <button id="mobile-menu-button" class="text-gray-700">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-6 w-6"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile menu, toggle visibility with JavaScript -->
      <div id="mobile-menu" class="hidden md:hidden mt-4 pb-2">
        <div class="flex flex-col space-y-3">
          <a href="/" class="text-gray-700 hover:text-orange-500 font-medium"
            >Home</a
          >
          <a
            href="/app/waf-sync"
            class="text-gray-700 hover:text-orange-500 font-medium"
            >WAF Sync Tool</a
          >
          <a
            href="/app/export-zones"
            class="text-gray-700 hover:text-orange-500 font-medium"
            >Data Export Tool</a
          >
          <a
            href="/blog"
            class="text-gray-700 hover:text-orange-500 font-medium">Blog</a
          >
        </div>
      </div>
    </nav>

    <script>
      // Mobile menu toggle
      document
        .getElementById("mobile-menu-button")
        ?.addEventListener("click", () => {
          const menu = document.getElementById("mobile-menu");
          menu?.classList.toggle("hidden");
        });
    </script>

    <main>
      <section class="bg-gradient-to-br from-gray-900 to-gray-800 text-white">
        <div class="max-w-7xl mx-auto px-6 py-16 md:py-20">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div>
              <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-4">
                Apply Cloudflare WAF Configs Across Multiple Sites
              </h1>
              <p class="text-gray-300 text-lg mb-8">
                Apply Cloudflare WAF rules to all your websites with just a few
                clicks. Save hours of manual configuration, ensure consistency,
                and strengthen your security posture.
              </p>
              <div class="flex flex-col sm:flex-row gap-4 mb-8">
                <a
                  href="/app/waf-copy"
                  class="bg-orange-500 hover:bg-orange-600 text-white font-medium py-3 px-6 rounded-lg text-center transition-colors"
                >
                  Go to WAF Sync Tool
                </a>
                <a
                  href="/app/export-zones"
                  class="bg-transparent border border-white hover:bg-white hover:text-gray-900 text-white font-medium py-3 px-6 rounded-lg text-center transition-colors"
                >
                  Zone Export Tool
                </a>
              </div>
            </div>

            <div class="mx-auto lg:mx-0 w-full max-w-2xl">
              <div
                class="relative rounded-lg overflow-hidden shadow-2xl bg-gray-800 border border-gray-700"
              >
                <div class="aspect-w-16 aspect-h-9">
                  <!-- Replace with your actual video embed -->
                  <div
                    class="w-full h-full flex items-center justify-center bg-gray-800"
                  >
                    <div class="text-center p-6">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-16 w-16 text-orange-500 mx-auto mb-4"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"
                        ></path>
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                      </svg>
                      <p class="text-gray-400">
                        Watch Demo: How to Sync WAF Rules
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
      <!-- How It Works Section -->
      <section class="py-16 bg-white">
        <div class="max-w-7xl mx-auto px-6">
          <div class="text-center mb-12">
            <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
              How It Works
            </h2>
            <p class="text-gray-600 mt-4 text-lg">
              Simple steps to sync your WAF configurations across multiple sites
            </p>
          </div>

          <div class="grid md:grid-cols-3 gap-8 mt-12">
            <!-- Step 1 -->
            <div class="flex flex-col items-center text-center">
              <div class="bg-orange-100 rounded-full p-5 mb-6">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-10 w-10 text-orange-500"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"
                  ></path>
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-gray-900 mb-3">
                1. Connect Your Account
              </h3>
              <p class="text-gray-700">
                Enter your Cloudflare API credentials to securely connect to
                your account and view all available zones.
              </p>
            </div>

            <!-- Step 2 -->
            <div class="flex flex-col items-center text-center">
              <div class="bg-orange-100 rounded-full p-5 mb-6">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-10 w-10 text-orange-500"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
                  ></path>
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-gray-900 mb-3">
                2. Select Source & Targets
              </h3>
              <p class="text-gray-700">
                Choose a source zone with your desired WAF configuration and
                select the target zones where you want to apply these rules.
              </p>
            </div>

            <!-- Step 3 -->
            <div class="flex flex-col items-center text-center">
              <div class="bg-orange-100 rounded-full p-5 mb-6">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-10 w-10 text-orange-500"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 13l4 4L19 7"></path>
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-gray-900 mb-3">
                3. Sync & Deploy
              </h3>
              <p class="text-gray-700">
                Review the changes and click deploy. The tool will automatically
                sync your WAF rules across all selected sites.
              </p>
            </div>
          </div>

          <div
            class="mt-16 bg-gray-50 border border-gray-200 rounded-lg p-8 shadow-sm"
          >
            <div
              class="flex flex-col md:flex-row items-center justify-between gap-6"
            >
              <div class="md:w-2/3">
                <h3 class="text-2xl font-semibold text-gray-900 mb-2">
                  Before & After Comparison
                </h3>
                <p class="text-gray-700">
                  The tool provides a detailed report showing the changes made
                  to each zone, including added, modified, and deleted rules.
                  You can review exactly what changed before and after the sync
                  operation.
                </p>
              </div>
              <div class="md:w-1/3 flex-shrink-0">
                <img
                  src="/api/placeholder/300/200"
                  alt="Before and after comparison"
                  class="rounded-lg shadow-md"
                />
              </div>
            </div>
          </div>

          <div class="mt-12 text-center">
            <a
              href="/app/waf-copy"
              class="inline-flex items-center bg-orange-500 hover:bg-orange-600 text-white font-medium py-3 px-6 rounded-lg transition-colors"
            >
              Try It Now
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5 ml-2"
                viewBox="0 0 20 20"
                fill="currentColor"
              >
                <path
                  fill-rule="evenodd"
                  d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z"
                  clip-rule="evenodd"></path>
              </svg>
            </a>
          </div>
        </div>
      </section>
      <!-- FAQ Section -->
      <section class="bg-gray-100 py-16">
        <div class="max-w-7xl mx-auto px-6">
          <div class="text-center mb-12">
            <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
              Frequently Asked Questions
            </h2>
            <p class="text-gray-600 mt-4 text-lg">
              Everything you need to know about the WAF Sync Tool
            </p>
          </div>

          <div class="grid gap-6 md:grid-cols-2 max-w-4xl mx-auto">
            <!-- FAQ Item 1 -->
            <div
              class="bg-white rounded-lg shadow-md p-6 border border-gray-200"
            >
              <h3 class="text-xl font-semibold text-gray-900 mb-3">
                What is the WAF Sync Tool?
              </h3>
              <p class="text-gray-700">
                The WAF Sync Tool allows you to apply Cloudflare WAF
                configurations across multiple sites simultaneously, eliminating
                the need for manual configuration on each domain.
              </p>
            </div>

            <!-- FAQ Item 2 -->
            <div
              class="bg-white rounded-lg shadow-md p-6 border border-gray-200"
            >
              <h3 class="text-xl font-semibold text-gray-900 mb-3">
                Do I need a Cloudflare API key?
              </h3>
              <p class="text-gray-700">
                Yes, you'll need a Cloudflare API key with sufficient
                permissions to read and modify WAF configurations across your
                domains.
              </p>
            </div>

            <!-- FAQ Item 3 -->
            <div
              class="bg-white rounded-lg shadow-md p-6 border border-gray-200"
            >
              <h3 class="text-xl font-semibold text-gray-900 mb-3">
                Which WAF rules can I sync?
              </h3>
              <p class="text-gray-700">
                You can sync all Cloudflare WAF rule types including managed
                rules, rate limiting rules, and custom rules across your
                domains.
              </p>
            </div>

            <!-- FAQ Item 4 -->
            <div
              class="bg-white rounded-lg shadow-md p-6 border border-gray-200"
            >
              <h3 class="text-xl font-semibold text-gray-900 mb-3">
                Is there a backup before changes are applied?
              </h3>
              <p class="text-gray-700">
                Yes, the tool automatically creates a backup of your existing
                WAF configurations before applying any changes, allowing you to
                restore if needed.
              </p>
            </div>

            <!-- FAQ Item 5 -->
            <div
              class="bg-white rounded-lg shadow-md p-6 border border-gray-200"
            >
              <h3 class="text-xl font-semibold text-gray-900 mb-3">
                What's the difference between the WAF Sync and Zone Export
                tools?
              </h3>
              <p class="text-gray-700">
                The WAF Sync Tool applies rules across multiple sites, while the
                Zone Export Tool allows you to export a complete WAF
                configuration from a single zone for documentation or backup
                purposes.
              </p>
            </div>

            <!-- FAQ Item 6 -->
            <div
              class="bg-white rounded-lg shadow-md p-6 border border-gray-200"
            >
              <h3 class="text-xl font-semibold text-gray-900 mb-3">
                Are there any rate limiting concerns?
              </h3>
              <p class="text-gray-700">
                The tool respects Cloudflare's API rate limits and includes
                throttling mechanisms to prevent your account from being
                temporarily blocked.
              </p>
            </div>
          </div>

          <div class="text-center mt-10">
            <a
              href="/app/waf-copy"
              class="inline-flex items-center bg-orange-500 hover:bg-orange-600 text-white font-medium py-3 px-6 rounded-lg transition-colors"
            >
              Get Started
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5 ml-2"
                viewBox="0 0 20 20"
                fill="currentColor"
              >
                <path
                  fill-rule="evenodd"
                  d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z"
                  clip-rule="evenodd"></path>
              </svg>
            </a>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
