---
import faq from "./faq.json";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import BaseHead from "@components/BaseHead.astro";

import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
---

<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-gray-50 text-gray-900">
    <Header />

    <main>
      <section class="bg-gradient-to-br from-gray-900 to-gray-800 text-white">
        <div class="max-w-7xl mx-auto px-6 py-16 md:py-20">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div>
              <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-4">
                Manage Cloudflare rules across a large number of domains
              </h1>
              <p class="text-gray-300 text-lg mb-8">
                Apply Cloudflare rules to all your websites with just a few
                clicks. Save hours of manual configuration, ensure consistency,
                and strengthen your security posture.
              </p>
              <div class="flex flex-col sm:flex-row gap-4 mb-8">
                <a
                  href="/waf-copy"
                  class="bg-pink-800 hover:bg-pink-600 text-white font-medium py-3 px-6 rounded-lg text-center transition-colors"
                >
                  Go to WAF Sync Tool
                </a>
                <a
                  href="/export-zones"
                  class="bg-transparent border border-white hover:bg-white hover:text-gray-900 text-white font-medium py-3 px-6 rounded-lg text-center transition-colors"
                >
                  Zone Export Tool
                </a>
              </div>
            </div>

            <div class="mx-auto lg:mx-0 w-full max-w-2xl">
              <div
                class="relative rounded-lg overflow-hidden shadow-2xl bg-gray-800 border border-gray-700"
              >
                <div class="aspect-w-16 aspect-h-9">
                  <!-- Replace with your actual video embed -->
                  <div
                    class="w-full h-full flex items-center justify-center bg-gray-800"
                  >
                    <div class="text-center p-6">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-16 w-16 text-pink-800 mx-auto mb-4"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"
                        ></path>
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                      </svg>
                      <p class="text-gray-400">
                        Watch Demo: How to Sync WAF Rules
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
      <section class="bg-gray-100 py-16">
        <div class="max-w-7xl mx-auto px-6">
          <div class="text-center mb-12">
            <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
              How It Works
            </h2>
            <p class="text-lg text-gray-600 max-w-3xl mx-auto">
              Synchronize your WAF configurations across multiple sites in five
              simple steps
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <!-- Step 1 -->
            <div class="bg-white p-6 rounded-lg shadow-md">
              <div class="flex items-center mb-4">
                <div
                  class="flex items-center justify-center h-12 w-12 rounded-full bg-pink-100 text-pink-800 font-bold text-xl mr-4"
                >
                  1
                </div>
                <h3 class="font-semibold text-xl">Prepare Your Zone List</h3>
              </div>
              <p class="text-gray-600">
                Create a CSV with zone IDs, names, API emails, and API keys for
                your target sites, or use our <a
                  href="/app/zone-waf-export"
                  class="text-pink-800 hover:text-pink-600">Zone Export Tool</a
                >.
              </p>
            </div>

            <!-- Step 2 -->
            <div class="bg-white p-6 rounded-lg shadow-md">
              <div class="flex items-center mb-4">
                <div
                  class="flex items-center justify-center h-12 w-12 rounded-full bg-pink-100 text-pink-800 font-bold text-xl mr-4"
                >
                  2
                </div>
                <h3 class="font-semibold text-xl">Source Configuration</h3>
              </div>
              <p class="text-gray-600">
                Identify the source zone ID, API email, and API key for the zone
                containing your preferred WAF configuration.
              </p>
            </div>

            <!-- Step 3 -->
            <div class="bg-white p-6 rounded-lg shadow-md">
              <div class="flex items-center mb-4">
                <div
                  class="flex items-center justify-center h-12 w-12 rounded-full bg-pink-100 text-pink-800 font-bold text-xl mr-4"
                >
                  3
                </div>
                <h3 class="font-semibold text-xl">Enter Details</h3>
              </div>
              <p class="text-gray-600">
                Navigate to the Copy page and input both your source credentials
                and target zone information.
              </p>
            </div>

            <!-- Step 4 -->
            <div class="bg-white p-6 rounded-lg shadow-md">
              <div class="flex items-center mb-4">
                <div
                  class="flex items-center justify-center h-12 w-12 rounded-full bg-pink-100 text-pink-800 font-bold text-xl mr-4"
                >
                  4
                </div>
                <h3 class="font-semibold text-xl">Review Copy Plan</h3>
              </div>
              <p class="text-gray-600">
                Click "Create Copy Plan" to preview which rules will be
                synchronized across your specified zones.
              </p>
            </div>

            <!-- Step 5 -->
            <div class="bg-white p-6 rounded-lg shadow-md">
              <div class="flex items-center mb-4">
                <div
                  class="flex items-center justify-center h-12 w-12 rounded-full bg-pink-100 text-pink-800 font-bold text-xl mr-4"
                >
                  5
                </div>
                <h3 class="font-semibold text-xl">Apply Changes</h3>
              </div>
              <p class="text-gray-600">
                Confirm and click "Apply" to securely deploy your WAF
                configurations across all target zones.
              </p>
            </div>
          </div>

          <div class="mt-12 text-center">
            <a
              href="/waf-copy"
              class="bg-pink-800 hover:bg-pink-600 text-white font-medium py-3 px-8 rounded-lg transition-colors"
            >
              Go to WAF Sync Tool
            </a>
          </div>
        </div>
      </section>
      <!-- FAQ Section -->
      <section class="bg-gray-100 py-16">
        <div class="max-w-7xl mx-auto px-6">
          <div class="text-center mb-12">
            <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
              Frequently Asked Questions
            </h2>
          </div>

          <div class="grid gap-6 md:grid-cols-2 max-w-4xl mx-auto">
            {
              faq.map((item) => (
                <div class="bg-white rounded-lg shadow-md p-6 border border-gray-200">
                  <h3 class="text-xl font-semibold text-gray-900 mb-3">
                    {item.question}
                  </h3>
                  <p class="text-gray-700">{item.answer}</p>
                </div>
              ))
            }
          </div>

          <div class="text-center mt-10">
            <a
              href="/waf-copy"
              class="inline-flex items-center bg-pink-800 hover:bg-pink-600 text-white font-medium py-3 px-6 rounded-lg transition-colors"
            >
              Go to WAF Sync Tool
            </a>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
