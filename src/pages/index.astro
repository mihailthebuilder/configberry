---
import "@styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>WAF Rules Manager | Bulk Cloudflare WAF Rule Management</title>
  </head>
  <body class="bg-gray-50 text-gray-900">
    <nav class="bg-white border-b border-gray-200 py-4 px-6 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto flex justify-between items-center">
        <div class="flex items-center space-x-2">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-8 w-8 text-orange-500"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
            <path d="M2 17l10 5 10-5"></path>
            <path d="M2 12l10 5 10-5"></path>
          </svg>
          <span class="font-bold text-xl text-gray-800">CloudSync</span>
        </div>

        <div class="hidden md:flex space-x-8">
          <a href="/" class="text-gray-700 hover:text-orange-500 font-medium"
            >Home</a
          >
          <a
            href="/waf-sync"
            class="text-gray-700 hover:text-orange-500 font-medium"
            >WAF Sync Tool</a
          >
          <a
            href="/data-export"
            class="text-gray-700 hover:text-orange-500 font-medium"
            >Data Export</a
          >
          <a
            href="/docs"
            class="text-gray-700 hover:text-orange-500 font-medium"
            >Documentation</a
          >
        </div>

        <div class="md:hidden">
          <button id="mobile-menu-button" class="text-gray-700">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-6 w-6"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </button>
        </div>

        <div class="hidden">
          <a
            href="https://github.com/yourusername/cloudsync"
            class="flex items-center text-gray-700 hover:text-orange-500"
            target="_blank"
            rel="noopener"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5 mr-1"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
            GitHub
          </a>
        </div>
      </div>

      <!-- Mobile menu, toggle visibility with JavaScript -->
      <div id="mobile-menu" class="hidden md:hidden mt-4 pb-2">
        <div class="flex flex-col space-y-3">
          <a href="/" class="text-gray-700 hover:text-orange-500 font-medium"
            >Home</a
          >
          <a
            href="/waf-sync"
            class="text-gray-700 hover:text-orange-500 font-medium"
            >WAF Sync Tool</a
          >
          <a
            href="/data-export"
            class="text-gray-700 hover:text-orange-500 font-medium"
            >Data Export</a
          >
          <a
            href="/docs"
            class="text-gray-700 hover:text-orange-500 font-medium"
            >Documentation</a
          >
        </div>
      </div>
    </nav>

    <script>
      // Mobile menu toggle
      document
        .getElementById("mobile-menu-button")
        ?.addEventListener("click", () => {
          const menu = document.getElementById("mobile-menu");
          menu?.classList.toggle("hidden");
        });
    </script>

    <main>
      <section class="bg-gradient-to-br from-gray-900 to-gray-800 text-white">
        <div class="max-w-7xl mx-auto px-6 py-20 md:py-24">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
            <div>
              <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-4">
                Sync Cloudflare Configurations Across Multiple Sites
              </h1>
              <p class="text-gray-300 text-lg mb-8">
                Deploy WAF rules and other Cloudflare configurations to all your
                websites with just a few clicks. Save time, ensure consistency,
                and strengthen your security posture.
              </p>
              <div class="flex flex-col sm:flex-row gap-4">
                <a
                  href="/waf-sync"
                  class="bg-orange-500 hover:bg-orange-600 text-white font-medium py-3 px-6 rounded-lg text-center transition-colors"
                >
                  Get Started with WAF Sync
                </a>
                <a
                  href="/data-export"
                  class="bg-transparent border border-white hover:bg-white hover:text-gray-900 text-white font-medium py-3 px-6 rounded-lg text-center transition-colors"
                >
                  Data Export Tool
                </a>
              </div>
            </div>
            <div class="hidden md:block">
              <div
                class="relative rounded-lg overflow-hidden shadow-2xl bg-gray-800 border border-gray-700"
              >
                <div
                  class="absolute inset-0 bg-gradient-to-br from-orange-500/10 to-blue-500/10"
                >
                </div>
                <img
                  src="/api/placeholder/600/400"
                  alt="Cloudflare WAF Sync dashboard"
                  class="w-full h-auto"
                />
              </div>
            </div>
          </div>
        </div>
        <div class="bg-gray-800 py-4">
          <div class="max-w-7xl mx-auto px-6 text-center">
            <p class="text-gray-400 mb-2">See how it works</p>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-6 w-6 text-orange-500 mx-auto animate-bounce"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
            </svg>
          </div>
        </div>
      </section>

      <!-- Video Demo Section -->
      <section class="py-16 bg-gray-50">
        <div class="max-w-5xl mx-auto px-6">
          <h2 class="text-3xl font-bold text-center mb-12">
            See CloudSync in Action
          </h2>
          <!-- Video demo placeholder - replace with your actual video embed -->
          <div class="aspect-w-16 aspect-h-9 bg-gray-200 rounded-lg shadow-lg">
            <!-- Replace with your actual video embed code -->
            <div class="w-full h-full flex items-center justify-center">
              <p class="text-gray-500">Video Demo Goes Here</p>
            </div>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
