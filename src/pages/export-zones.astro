---
import ZonesDownload from "@components/ZonesDownload";
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import BaseHead from "@components/BaseHead.astro";
---

<html lang="en">
  <head>
    <BaseHead
      title="ConfigBerry | Export Cloudflare Zones Tool"
      description="Export all zones for a list of Cloudflare accounts. All you need is a CSV file with account emails and API keys."
    />
  </head>
  <body>
    <Header />
    <main>
      <ZonesDownload client:only="react" />
    </main>
    <Footer />
  </body>
</html>
